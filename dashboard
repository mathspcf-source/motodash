<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    
    <!-- Meta tags PWA -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MotoDash">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#000000">
    <meta name="description" content="Dashboard para motoboys Uber Moto e 99 Moto">
    
    <title>MotoDash</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='100' fill='%23000'/%3E%3Ctext x='256' y='280' font-size='180' font-weight='900' text-anchor='middle' fill='white' font-family='Arial,sans-serif' letter-spacing='-4'%3EMoto%3C/text%3E%3Ctext x='256' y='400' font-size='120' font-weight='700' text-anchor='middle' fill='%2306c167' font-family='Arial,sans-serif' letter-spacing='8'%3EDash%3C/text%3E%3C/svg%3E">
    
    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" sizes="180x180" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='100' fill='%23000'/%3E%3Ctext x='256' y='280' font-size='180' font-weight='900' text-anchor='middle' fill='white' font-family='Arial,sans-serif' letter-spacing='-4'%3EMoto%3C/text%3E%3Ctext x='256' y='400' font-size='120' font-weight='700' text-anchor='middle' fill='%2306c167' font-family='Arial,sans-serif' letter-spacing='8'%3EDash%3C/text%3E%3C/svg%3E">
    
    <style>
        :root {
            --bg: #000;
            --card: #141414;
            --border: #1f1f1f;
            --text: #f5f5f5;
            --text-secondary: #8a8a8a;
            --uber: #06c167;
            --nove9: #ffc107;
            --red: #ff453a;
            --blue: #3b82f6;
            --radius: 16px;
            --safe-bottom: env(safe-area-inset-bottom, 16px);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, sans-serif;
            background: #000;
            color: #f5f5f5;
            min-height: 100dvh;
            max-width: 480px;
            margin: 0 auto;
            padding: 16px 16px calc(70px + var(--safe-bottom)) 16px;
            -webkit-font-smoothing: antialiased;
        }

        /* Splash Screen */
        .splash {
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
            transition: opacity 0.4s, visibility 0.4s;
        }
        .splash.hide {
            opacity: 0;
            visibility: hidden;
        }
        .splash-logo {
            width: 90px;
            height: 90px;
            background: #000;
            border: 3px solid #fff;
            border-radius: 22px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            animation: splashPulse 2s ease-in-out infinite;
        }
        @keyframes splashPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        .splash-logo-text {
            font-size: 28px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -1px;
            line-height: 1;
        }
        .splash-logo-sub {
            font-size: 18px;
            font-weight: 700;
            color: #06c167;
            letter-spacing: 3px;
            line-height: 1;
        }
        .splash-name {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
        }
        .splash-subtitle {
            font-size: 11px;
            color: #666;
        }
        .splash-loading {
            width: 40px;
            height: 3px;
            background: #1a1a1a;
            border-radius: 2px;
            overflow: hidden;
            margin-top: 8px;
        }
        .splash-loading-bar {
            height: 100%;
            width: 30%;
            background: #06c167;
            border-radius: 2px;
            animation: splashLoading 1s ease-in-out infinite;
        }
        @keyframes splashLoading {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(350%); }
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            padding: 4px 0;
        }
        .header-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .header-logo {
            width: 40px;
            height: 40px;
            background: #000;
            border: 2px solid #fff;
            border-radius: 11px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }
        .header-logo-top {
            font-size: 10px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -0.5px;
        }
        .header-logo-bottom {
            font-size: 7px;
            font-weight: 700;
            color: #06c167;
            letter-spacing: 1px;
        }
        .header-title {
            font-size: 19px;
            font-weight: 700;
            letter-spacing: -0.02em;
        }
        .header-subtitle {
            font-size: 10px;
            color: #8a8a8a;
            font-weight: 500;
        }
        .badge-row {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }
        .badge {
            padding: 5px 9px;
            border-radius: 14px;
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.02em;
        }
        .badge-streak {
            background: #06c16715;
            color: #06c167;
            border: 1px solid #06c16730;
        }
        .badge-record {
            background: #ffc10715;
            color: #ffc107;
            border: 1px solid #ffc10730;
        }

        .empty-dashboard {
            text-align: center;
            padding: 60px 20px;
            color: #3a3a3a;
        }
        .empty-dashboard .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.25;
        }
        .empty-dashboard .empty-text {
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 6px;
            color: #444;
        }
        .empty-dashboard .empty-sub {
            font-size: 11px;
            color: #333;
            line-height: 1.5;
        }
        .empty-dashboard .empty-action {
            display: inline-block;
            margin-top: 16px;
            padding: 10px 20px;
            background: #fff;
            color: #000;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            border: none;
            transition: all 0.15s;
        }
        .empty-dashboard .empty-action:active {
            transform: scale(0.96);
            background: #e0e0e0;
        }

        .mes-selector {
            display: none;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 12px;
            background: #141414;
            border-radius: 14px;
            padding: 6px 8px;
            border: 1px solid #1f1f1f;
        }
        .mes-selector.visible {
            display: flex;
        }
        .mes-btn {
            background: #1a1a1a;
            border: 1px solid #2a2a2a;
            color: #fff;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s;
            flex-shrink: 0;
        }
        .mes-btn:active {
            background: #333;
            border-color: #444;
        }
        .mes-btn.hoje {
            width: auto;
            border-radius: 16px;
            padding: 0 12px;
            font-size: 10px;
            font-weight: 700;
            color: #06c167;
            border-color: #06c16740;
            background: #06c16710;
            letter-spacing: 0.03em;
        }
        .mes-info {
            flex: 1;
            text-align: center;
            min-width: 0;
        }
        .mes-nome {
            font-size: 14px;
            font-weight: 700;
            letter-spacing: -0.01em;
            color: #fff;
        }
        .mes-total {
            font-size: 9px;
            color: #5a5a5a;
            margin-top: 1px;
            font-weight: 500;
        }

        .dashboard-section {
            display: none;
        }
        .dashboard-section.visible {
            display: block;
        }
        .dashboard-section.grid {
            display: none;
        }
        .dashboard-section.grid.visible {
            display: grid;
        }

        .metas-card {
            background: #141414;
            border-radius: 16px;
            padding: 14px 16px;
            margin-bottom: 10px;
            border: 1px solid #1f1f1f;
        }
        .meta-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            cursor: pointer;
        }
        .meta-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .meta-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .meta-dot.bruta {
            background: #06c167;
            box-shadow: 0 0 6px #06c16750;
        }
        .meta-dot.liquida {
            background: #3b82f6;
            box-shadow: 0 0 6px #3b82f650;
        }
        .meta-label {
            font-size: 11px;
            color: #8a8a8a;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .meta-value {
            font-size: 12px;
            font-weight: 700;
            text-align: right;
        }
        .meta-track {
            height: 4px;
            background: #1f1f1f;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 10px;
        }
        .meta-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 0.6s;
        }
        .meta-fill.bruta {
            background: linear-gradient(90deg, #06c167, #00e676);
        }
        .meta-fill.liquida {
            background: linear-gradient(90deg, #3b82f6, #60a5fa);
        }
        .meta-fill.completed {
            box-shadow: 0 0 8px currentColor;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 10px;
        }
        .stat-card {
            background: #141414;
            border-radius: 14px;
            padding: 14px;
            border: 1px solid #1f1f1f;
        }
        .stat-card.span-2 {
            grid-column: span 2;
        }
        .stat-label {
            font-size: 10px;
            color: #8a8a8a;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 600;
            margin-bottom: 4px;
        }
        .stat-value {
            font-size: 24px;
            font-weight: 700;
        }
        .stat-value.green {
            color: #06c167;
        }
        .stat-value.yellow {
            color: #ffc107;
        }

        .semanal-card {
            background: #141414;
            border-radius: 14px;
            padding: 14px;
            border: 1px solid #1f1f1f;
            margin-bottom: 10px;
        }
        .semanal-title {
            font-size: 10px;
            color: #8a8a8a;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 600;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .semanal-bars {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            height: 80px;
            padding: 0 2px;
        }
        .semanal-bar-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            height: 100%;
            justify-content: flex-end;
        }
        .semanal-bar {
            width: 100%;
            max-width: 32px;
            border-radius: 5px 5px 0 0;
            transition: height 0.5s;
            min-height: 2px;
        }
        .semanal-bar.uber {
            background: linear-gradient(180deg, #06c167, #00a050);
        }
        .semanal-bar.nove9 {
            background: linear-gradient(180deg, #ffc107, #e6a800);
        }
        .semanal-dia {
            font-size: 8px;
            color: #666;
            text-align: center;
        }
        .semanal-val {
            font-size: 7px;
            color: #888;
            text-align: center;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 10px;
        }
        .chart-card {
            background: #141414;
            border-radius: 14px;
            padding: 14px;
            border: 1px solid #1f1f1f;
            text-align: center;
        }
        .chart-card.full {
            grid-column: span 2;
        }
        .chart-title {
            font-size: 10px;
            color: #8a8a8a;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 600;
            margin-bottom: 10px;
        }
        .donut-wrap {
            position: relative;
            width: 90px;
            height: 90px;
            margin: 0 auto 6px;
        }
        .donut-wrap svg {
            width: 90px;
            height: 90px;
            transform: rotate(-90deg);
        }
        .donut-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            justify-content: center;
            font-size: 9px;
        }
        .donut-legend span {
            display: flex;
            align-items: center;
            gap: 3px;
            color: #8a8a8a;
            font-weight: 500;
        }
        .legend-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .bar-chart {
            padding: 0 2px;
        }
        .bar-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 7px;
            font-size: 10px;
        }
        .bar-row.separator {
            border-top: 1px dashed #222;
            padding-top: 7px;
            margin-top: 3px;
        }
        .bar-label {
            width: 68px;
            font-weight: 600;
            color: #bbb;
            font-size: 9px;
        }
        .bar-track {
            flex: 1;
            height: 16px;
            background: #1a1a1a;
            border-radius: 8px;
            overflow: hidden;
        }
        .bar-fill {
            height: 100%;
            border-radius: 8px;
            transition: width 0.5s;
        }
        .bar-val {
            width: 75px;
            text-align: right;
            font-size: 9px;
            color: #8a8a8a;
            font-weight: 600;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1px;
            background: #1f1f1f;
            border-radius: 14px;
            overflow: hidden;
            margin-bottom: 10px;
        }
        .kpi-cell {
            background: #141414;
            padding: 11px 6px;
            text-align: center;
        }
        .kpi-val {
            font-size: 16px;
            font-weight: 700;
        }
        .kpi-val.accent {
            color: #06c167;
        }
        .kpi-label {
            font-size: 8px;
            color: #5a5a5a;
            margin-top: 2px;
        }

        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 480px;
            background: #0a0a0af0;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            display: flex;
            padding: 6px 8px calc(6px + var(--safe-bottom)) 8px;
            gap: 4px;
            border-top: 1px solid #1a1a1a;
            z-index: 100;
        }
        .nav-item {
            flex: 1;
            padding: 9px 4px;
            text-align: center;
            font-size: 9px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            color: #666;
            transition: all 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
        }
        .nav-item.active {
            color: #06c167;
            background: #06c16710;
        }

        .page {
            display: none;
        }
        .page.active {
            display: block;
        }

        .form-group {
            margin-bottom: 10px;
        }
        .form-label {
            display: block;
            font-size: 10px;
            color: #8a8a8a;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
        }
        .form-input,
        .form-select {
            width: 100%;
            background: #111;
            border: 1px solid #1f1f1f;
            color: #fff;
            padding: 10px 12px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
        }
        .form-input:focus,
        .form-select:focus {
            border-color: #333;
            outline: none;
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .btn {
            width: 100%;
            padding: 12px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.15s;
        }
        .btn:active {
            transform: scale(0.98);
        }
        .btn-primary {
            background: #fff;
            color: #000;
        }
        .btn-secondary {
            background: transparent;
            border: 1px solid #2a2a2a;
            color: #fff;
        }
        .btn-sm {
            width: auto;
            padding: 7px 12px;
            font-size: 10px;
            border-radius: 8px;
            font-weight: 600;
        }
        .btn-outline {
            background: transparent;
            border: 1px solid #2a2a2a;
            color: #aaa;
            font-size: 11px;
            padding: 9px;
            font-weight: 600;
        }
        .btn-outline.uber-btn {
            border-color: #06c16730;
            color: #06c167;
        }
        .btn-outline.nove9-btn {
            border-color: #ffc10730;
            color: #ffc107;
        }
        .btn-tag {
            width: auto;
            padding: 7px 12px;
            font-size: 10px;
            border-radius: 10px;
            background: #111;
            border: 1px solid #222;
            color: #999;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-tag.active {
            background: #fff;
            border-color: #fff;
            color: #000;
        }

        .record-item {
            background: #141414;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 6px;
            border: 1px solid #1f1f1f;
        }
        .record-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 4px;
        }
        .record-date {
            font-weight: 600;
            font-size: 13px;
        }
        .record-value {
            font-weight: 700;
            font-size: 15px;
            color: #06c167;
        }
        .record-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            font-size: 9px;
        }
        .record-tag {
            background: #1a1a1a;
            padding: 3px 7px;
            border-radius: 6px;
            color: #888;
        }
        .record-apps {
            display: flex;
            gap: 5px;
            margin-top: 4px;
            flex-wrap: wrap;
        }
        .record-app {
            font-size: 9px;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .record-app.uber {
            background: #06c16715;
            color: #06c167;
        }
        .record-app.nove9 {
            background: #ffc10715;
            color: #ffc107;
        }
        .app-ind {
            width: 5px;
            height: 5px;
            border-radius: 50%;
        }
        .app-ind.uber {
            background: #06c167;
        }
        .app-ind.nove9 {
            background: #ffc107;
        }

        .maint-item {
            background: #141414;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 6px;
            border: 1px solid #1f1f1f;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .maint-item.warning {
            border-left: 3px solid #ffc107;
        }
        .maint-item.danger {
            border-left: 3px solid #ff453a;
        }
        .maint-info strong {
            font-size: 12px;
        }
        .maint-info small {
            font-size: 9px;
            color: #666;
            display: block;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            z-index: 200;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .modal-overlay.show {
            display: flex;
        }
        .modal {
            background: #141414;
            border-radius: 20px;
            padding: 20px;
            width: 100%;
            max-width: 360px;
            border: 1px solid #222;
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }
        .modal-title {
            font-size: 16px;
            font-weight: 700;
        }
        .modal-close {
            background: none;
            border: none;
            color: #fff;
            font-size: 22px;
            cursor: pointer;
            padding: 4px;
            opacity: 0.7;
        }

        .footer-credit {
            text-align: center;
            padding: 12px;
            font-size: 9px;
            color: #333;
            margin-top: 8px;
        }

        .info-box {
            background: #1a1a0a;
            border: 1px solid #3a3a0a;
            border-radius: 10px;
            padding: 8px 10px;
            font-size: 9px;
            color: #ffc107;
            margin-top: 8px;
            text-align: center;
        }

        .color-input {
